# ── RemotelyAvailable.com Environment Variables ──

# Contact Form → n8n Auto Query Responder
N8N_WEBHOOK_URL=
N8N_WEBHOOK_SECRET=

# AI Chatbot → n8n Chat Trigger
N8N_CHAT_WEBHOOK_URL=

# Lead Capture Popup → n8n Lead Follow-up
N8N_LEAD_WEBHOOK_URL=

# SMTP Email Notifications (contact form → your inbox)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
NOTIFY_EMAIL=hello@remotelyavailable.com

# Calendly booking page URL
NEXT_PUBLIC_CALENDLY_URL=

# EmailOctopus — Shopify Playbook Lead Capture
EMAILOCTOPUS_API_KEY=
EMAILOCTOPUS_SHOPIFY_LIST_ID=
